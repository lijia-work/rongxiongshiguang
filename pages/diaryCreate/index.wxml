<!--pages/diaryCreate/index.wxml-->
<!-- 自定义导航栏 -->
<view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-content">
    <view class="nav-back" bindtap="goBack">‹</view>
    <text class="nav-title">{{isEdit ? '编辑日记' : '写日记'}}</text>
  </view>
</view>

<view class="container" style="padding-top: {{statusBarHeight + 44}}px;">
  <!-- 日期选择 -->
  <view class="form-group">
    <text class="form-label">日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="picker-field">{{date}}</view>
    </picker>
  </view>

  <!-- 心情选择 -->
  <view class="form-group">
    <text class="form-label">心情</text>
    <view class="mood-selector">
      <view
        wx:for="{{moodOptions}}"
        wx:key="*this"
        class="mood-option {{selectedMood === item ? 'selected' : ''}}"
        bindtap="selectMood"
        data-mood="{{item}}"
      >{{item}}</view>
    </view>
  </view>

  <!-- 日记内容 -->
  <view class="form-group">
    <text class="form-label">内容</text>
    <textarea
      class="textarea-field"
      placeholder="记录今天的故事..."
      placeholder-style="color: #B3A28E; line-height: 1.6;"
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="500"
    />
    <text class="char-count">{{content.length}}/500</text>
  </view>

  <!-- 添加图片 -->
  <view class="form-group">
    <text class="form-label">图片 (最多3张)</text>
    <view class="image-list">
      <view wx:for="{{images}}" wx:key="*this" class="image-item">
        <image src="{{item}}" class="preview-img" mode="aspectFill" />
        <view class="remove-img" bindtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view wx:if="{{images.length < 3}}" class="add-image" bindtap="chooseImage">
        <text>➕</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-primary" bindtap="saveDiary">💾 保存日记</button>
    <button wx:if="{{isEdit}}" class="btn-danger" bindtap="deleteDiary">🗑️ 删除日记</button>
  </view>
</view>