/* pages/diaryCreate/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
}

/* 心情选择 */
.mood-selector {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.mood-option {
  width: 48px;
  height: 48px;
  background: #F7E5D3;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  border: 2px solid transparent;
}

.mood-option.selected {
  border-color: #D9A13B;
  background: #FFF0E0;
}

/* 文本域 */
.textarea-field {
  width: 100%;
  min-height: 150px;
  padding: 14px 16px;
  border-radius: 24px;
  border: 1px solid #E8DDD2;
  background: white;
  font-size: 14px;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: #B3A28E;
  margin-top: 4px;
}

/* 图片列表 */
.image-list {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.image-item {
  position: relative;
}

.preview-img {
  width: 80px;
  height: 80px;
  border-radius: 12px;
}

.remove-img {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 20px;
  height: 20px;
  background: #C23D3D;
  color: white;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.add-image {
  width: 80px;
  height: 80px;
  background: #FEF3E4;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  color: #D9A13B;
  border: 1px dashed #D9A13B;
}

/* 按钮 */
.action-buttons {
  margin-top: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn-primary {
  background: #D9A13B;
  color: white;
  border-radius: 40px;
  padding: 14px 24px;
  text-align: center;
  font-weight: 600;
  font-size: 16px;
}

.btn-danger {
  background: #C23D3D;
  color: white;
  border-radius: 40px;
  padding: 14px 24px;
  text-align: center;
  font-weight: 600;
  font-size: 16px;
}