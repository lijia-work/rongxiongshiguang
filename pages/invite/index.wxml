<!--pages/invite/index.wxml-->
<!-- 自定义导航栏 -->
<view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-content">
    <view class="nav-back" bindtap="goBack">‹</view>
    <text class="nav-title">邀熊同玩</text>
  </view>
</view>

<view class="container" style="padding-top: {{statusBarHeight + 44}}px;">
  <!-- 邀请卡片 -->
  <view class="invite-card">
    <view class="invite-header">
      <view class="logo">🐹</view>
      <view class="app-name">绒熊时光</view>
    </view>
    <view class="invite-content">
      <text class="invite-text">我的小熊在绒熊时光等我来照顾，</text>
      <text class="invite-text">快来一起养熊吧！</text>
    </view>
    <!-- 小程序码 -->
    <view class="qrcode-placeholder">
      <view class="qrcode-box">
        <image
          wx:if="{{qrcodeUrl}}"
          src="{{qrcodeUrl}}"
          class="qrcode-img"
          mode="aspectFit"
          show-menu-by-longpress="{{true}}"
        />
        <view wx:elif="{{qrcodeLoading}}" class="qrcode-loading">
          <text class="loading-text">加载中...</text>
        </view>
        <view wx:else class="qrcode-error" bindtap="reloadQrCode">
          <text class="error-icon">🔄</text>
          <text class="error-text">点击重试</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分享按钮 -->
  <button class="btn-share" open-type="share">
    📤 分享给好友
  </button>

  <!-- 保存海报按钮 -->
  <view class="btn-save-poster" bindtap="savePoster">
    🖼️ 保存分享海报
  </view>

  <!-- 说明 -->
  <view class="tips-section">
    <view class="tips-title">如何邀请好友？</view>
    <view class="tips-item">
      <text class="tips-num">1</text>
      <text class="tips-desc">点击"分享给好友"发送给微信好友或群聊</text>
    </view>
    <view class="tips-item">
      <text class="tips-num">2</text>
      <text class="tips-desc">保存分享海报，可发朋友圈或线下分享</text>
    </view>
    <view class="tips-item">
      <text class="tips-num">3</text>
      <text class="tips-desc">好友扫码即可加入绒熊时光</text>
    </view>
  </view>
</view>

<!-- 海报生成Canvas（隐藏） -->
<canvas
  type="2d"
  id="posterCanvas"
  canvas-id="posterCanvas"
  class="poster-canvas"
  style="width: 300px; height: 400px; position: fixed; left: -9999px; top: -9999px;"
></canvas>