/* pages/todo/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
}

/* 添加区域 */
.add-section {
  background: white;
  border-radius: 24px;
  padding: 16px;
  margin-bottom: 20px;
  border: 1px solid #F2E8DF;
}

.btn-add {
  background: #D9A13B;
  color: white;
  border-radius: 40px;
  padding: 14px;
  font-weight: 600;
  font-size: 16px;
  margin-top: 8px;
}

/* 提醒列表 */
.todo-section {
  margin-top: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #3E2C1F;
  margin-bottom: 12px;
}

.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: #B3A28E;
}

.empty-tip {
  font-size: 12px;
  margin-top: 8px;
  display: block;
}

.todo-item {
  background: white;
  border-radius: 20px;
  padding: 12px 16px;
  margin-bottom: 10px;
  border: 1px solid #F2E8DF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.todo-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.todo-icon {
  width: 40px;
  height: 40px;
  background: #FEF3E4;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.todo-info {
  display: flex;
  flex-direction: column;
}

.todo-content {
  font-weight: 600;
  color: #3E2C1F;
}

.todo-cycle {
  font-size: 12px;
  color: #B3A28E;
  margin-top: 2px;
}

.todo-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.todo-next {
  font-size: 12px;
  color: #D9A13B;
  background: #FEF3E4;
  padding: 4px 10px;
  border-radius: 12px;
}

.todo-delete {
  font-size: 18px;
  padding: 4px;
}