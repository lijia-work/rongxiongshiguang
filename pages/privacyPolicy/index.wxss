/* pages/privacyPolicy/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
  box-sizing: border-box;
  min-height: 100vh;
  background: #FFFCF8;
}

.content-card {
  background: white;
  border-radius: 24px;
  padding: 20px;
  border: 1px solid #F2E8DF;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #3E2C1F;
  text-align: center;
  margin-bottom: 8px;
}

.update-date {
  font-size: 12px;
  color: #B3A28E;
  text-align: center;
  margin-bottom: 20px;
}

.section {
  margin-bottom: 16px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #B45F2B;
  margin-bottom: 8px;
}

.section-content {
  font-size: 13px;
  color: #3E2C1F;
  line-height: 1.8;
  white-space: pre-wrap;
}