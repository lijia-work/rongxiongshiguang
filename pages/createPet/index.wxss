/* pages/createPet/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
  box-sizing: border-box;
}

/* 头像选择 */
.avatar-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 12px;
}

.avatar-option {
  width: 56px;
  height: 56px;
  background: #F7E5D3;
  border-radius: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  border: 2px solid transparent;
}

.avatar-option.selected {
  border-color: #D9A13B;
  background: #FFF0E0;
}

.upload-btn {
  background: #FEF3E4;
  color: #B45F2B;
  border-radius: 40px;
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 500;
  border: 1px solid #F2E8DF;
  margin-bottom: 12px;
}

.preview-img {
  width: 80px;
  height: 80px;
  border-radius: 40px;
  margin-top: 8px;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 24px;
}