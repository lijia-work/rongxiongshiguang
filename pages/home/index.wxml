<!--pages/home/index.wxml-->
<view class="container" style="padding-top: {{navBarTop + 16}}px;">
  <!-- 顶部标题 -->
  <view class="page-header" style="top: 0; height: {{navBarTop}}px;">
    <view class="header-content" style="padding-top: {{statusBarHeight}}px;">
      <text class="page-title">绒熊时光</text>
    </view>
  </view>

  <!-- 提醒栏 -->
  <view class="reminder-bar" bindtap="goToTodo">
    <view class="reminder-left">
      <text class="reminder-bell">⏰</text>
      <text class="reminder-text">{{reminderText}}</text>
    </view>
    <view class="reminder-badge">{{reminderBadge}}</view>
  </view>

  <!-- 宠物列表标题 -->
  <view class="section-header">
    <text class="section-title">🐻 我的小熊</text>
    <view class="section-actions">
      <!-- 搜索图标（展开时隐藏） -->
      <view class="search-icon-btn {{showSearchBar ? 'hidden' : ''}}" bindtap="toggleSearch">
        <text class="search-icon-text">🔍</text>
      </view>
      <!-- 展开的搜索框 -->
      <view class="search-expand-box {{showSearchBar ? 'expanded' : ''}}">
        <input
          class="search-expand-input"
          placeholder="搜索宠物名字"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindblur="onSearchBlur"
          focus="{{showSearchBar}}"
        />
        <text class="search-expand-close" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
      </view>
      <!-- 新建按钮 -->
      <text class="add-btn" bindtap="goToCreatePet">+ 新建</text>
    </view>
  </view>

  <!-- 宠物列表 -->
  <view class="pet-list" wx:if="{{filteredPets.length > 0}}">
    <view class="pet-card-wrapper" wx:for="{{filteredPets}}" wx:key="id">
      <!-- 操作按钮（右滑显示） -->
      <view class="pet-card-actions">
        <view class="action-btn edit-btn" catchtap="editPet" data-id="{{item.id}}">编辑</view>
        <view class="action-btn delete-btn" catchtap="deletePet" data-id="{{item.id}}">删除</view>
      </view>
      <!-- 卡片内容 -->
      <view
        class="pet-card {{swipePetId === item.id ? 'swiped' : ''}}"
        bindtap="goToPetDetail"
        data-id="{{item.id}}"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
      >
        <view class="pet-avatar">{{item.avatar || '🐹'}}</view>
        <view class="pet-info">
          <view class="pet-name">{{item.name}} · {{item.gender === '♂ 公' ? '♂' : '♀'}}</view>
          <view class="pet-days">🎂 已陪伴 {{item.days}} 天</view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredPets.length === 0}}">
    <text>🐾 没有找到叫这个名字的小熊，试试其他名字吧～</text>
  </view>
</view>

<!-- 操作菜单弹窗 -->
<view class="action-mask" wx:if="{{showActionMenu}}" bindtap="hideActionMenu">
  <view class="action-menu" catchtap="stopPropagation">
    <view class="menu-item" bindtap="goToCreatePet">
      <text class="menu-icon">➕</text>
      <text>创建宠物</text>
    </view>
    <view class="menu-item" bindtap="goToDiaryCreate">
      <text class="menu-icon">📝</text>
      <text>写日记</text>
    </view>
    <view class="menu-item" bindtap="goToTodo">
      <text class="menu-icon">⏲️</text>
      <text>待办提醒</text>
    </view>
    <view class="menu-close" bindtap="hideActionMenu">点击空白关闭</view>
  </view>
</view>