/* pages/home/index.wxss */

.container {
  padding: 16px;
  padding-bottom: calc(50px + env(safe-area-inset-bottom) + 20px);
  box-sizing: border-box;
  min-height: 100vh;
  background: #FFFCF8;
}

/* 顶部标题 */
.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #FFFCF8;
  z-index: 100;
  box-sizing: border-box;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 16px;
  padding-right: 16px;
  height: 44px;
}

.page-title {
  font-size: 22px;
  font-weight: 700;
  color: #D9A13B;
  text-align: left;
}

/* 提醒栏 */
.reminder-bar {
  background: #FEF3E4;
  border-radius: 24px;
  padding: 12px 16px;
  margin-bottom: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid #FCE5D2;
}

.reminder-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.reminder-bell {
  font-size: 22px;
}

.reminder-text {
  font-size: 14px;
  font-weight: 500;
  color: #B45F2B;
}

.reminder-badge {
  background: #D9A13B;
  color: white;
  border-radius: 30px;
  padding: 4px 12px;
  font-size: 12px;
}

/* 区块标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #3E2C1F;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* 搜索图标按钮 */
.search-icon-btn {
  width: 32px;
  height: 32px;
  background: #FEF3E4;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.search-icon-btn.hidden {
  width: 0;
  opacity: 0;
  overflow: hidden;
  margin: 0;
  padding: 0;
}

.search-icon-text {
  font-size: 16px;
}

/* 展开的搜索框 */
.search-expand-box {
  width: 0;
  height: 32px;
  background: #FEF3E4;
  border-radius: 16px;
  display: flex;
  align-items: center;
  padding: 0;
  overflow: hidden;
  transition: all 0.3s ease;
  opacity: 0;
}

.search-expand-box.expanded {
  width: 120px;
  padding: 0 12px;
  opacity: 1;
}

.search-expand-input {
  flex: 1;
  font-size: 13px;
  background: transparent;
  min-width: 0;
}

.search-expand-close {
  font-size: 14px;
  color: #B3A28E;
  padding: 4px;
  flex-shrink: 0;
}

.add-btn {
  font-size: 14px;
  color: #D9A13B;
  white-space: nowrap;
}

/* 宠物卡片 */
.pet-card-wrapper {
  position: relative;
  margin-bottom: 12px;
  overflow: hidden;
  border-radius: 24px;
}

.pet-card-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
}

.action-btn {
  width: 60px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 500;
  color: white;
}

.edit-btn {
  background: #D9A13B;
  border-radius: 0;
}

.delete-btn {
  background: #E85A4F;
  border-radius: 0 24px 24px 0;
}

.pet-card {
  background: white;
  border-radius: 24px;
  padding: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
  border: 1px solid #F2E8DF;
  display: flex;
  align-items: center;
  gap: 14px;
  position: relative;
  z-index: 1;
  transition: transform 0.2s ease;
}

.pet-card.swiped {
  transform: translateX(-120px);
}

.pet-avatar {
  width: 56px;
  height: 56px;
  background: #F7E5D3;
  border-radius: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-weight: 700;
  font-size: 16px;
  color: #3E2C1F;
}

.pet-days {
  font-size: 12px;
  color: #B3A28E;
  margin-top: 4px;
}

.arrow {
  color: #D9A13B;
  font-size: 18px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40px 0;
  color: #B3A28E;
  font-size: 14px;
}

/* 操作菜单 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.action-menu {
  background: white;
  width: 260px;
  border-radius: 32px;
  padding: 16px 0;
  box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.2);
}

.menu-item {
  padding: 14px 24px;
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 16px;
  font-weight: 500;
  border-bottom: 0.5px solid #F0E5DC;
  color: #3E2C1F;
}

.menu-item:last-of-type {
  border-bottom: none;
}

.menu-item:active {
  background: #F7F3EE;
}

.menu-icon {
  font-size: 22px;
  width: 32px;
}

.menu-close {
  text-align: center;
  font-size: 12px;
  color: #aaa;
  margin-top: 12px;
}