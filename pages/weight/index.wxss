/* pages/weight/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
}

.pet-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.pet-avatar {
  width: 48px;
  height: 48px;
  background: #F7E5D3;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
}

.pet-info {
  display: flex;
  flex-direction: column;
}

.pet-name {
  font-size: 16px;
  font-weight: 600;
  color: #3E2C1F;
}

.pet-weight {
  font-size: 12px;
  color: #D9A13B;
  margin-top: 2px;
}

/* 添加区域 */
.add-section {
  background: white;
  border-radius: 24px;
  padding: 16px;
  margin-bottom: 20px;
  border: 1px solid #F2E8DF;
}

.form-row {
  display: flex;
  gap: 12px;
}

.form-row .form-group {
  flex: 1;
}

.form-label {
  font-weight: 600;
  font-size: 12px;
  margin-bottom: 6px;
  display: block;
  color: #3E2C1F;
}

.btn-add {
  background: #D9A13B;
  color: white;
  border-radius: 40px;
  padding: 14px;
  font-weight: 600;
  font-size: 16px;
  margin-top: 4px;
}

/* 体重列表 */
.weight-section {
  margin-top: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #3E2C1F;
  margin-bottom: 12px;
}

.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: #B3A28E;
}

.weight-item {
  background: white;
  border-radius: 20px;
  padding: 12px 16px;
  margin-bottom: 10px;
  border: 1px solid #F2E8DF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.weight-left {
  display: flex;
  align-items: center;
}

.weight-date {
  font-size: 14px;
  color: #3E2C1F;
}

.weight-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.weight-value {
  font-size: 16px;
  font-weight: 600;
  color: #D9A13B;
}

.weight-delete {
  font-size: 18px;
  padding: 4px;
}