/* pages/profile/index.wxss */

.container {
  padding: 16px;
  padding-bottom: calc(50px + env(safe-area-inset-bottom) + 20px);
  box-sizing: border-box;
  min-height: 100vh;
  background: #FFFCF8;
}

/* 顶部标题 */
.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #FFFCF8;
  z-index: 100;
  box-sizing: border-box;
}

.header-content {
  display: flex;
  align-items: center;
  padding-left: 16px;
  padding-right: 16px;
  height: 44px;
}

.page-title {
  font-size: 22px;
  font-weight: 700;
  color: #D9A13B;
  text-align: left;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  gap: 16px;
  background: #FEF8F0;
  padding: 16px;
  border-radius: 28px;
  margin-bottom: 16px;
}

.user-avatar {
  width: 56px;
  height: 56px;
  background: #E3D5C5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.user-info-text {
  flex: 1;
}

.user-name {
  font-weight: 600;
  font-size: 18px;
  color: #3E2C1F;
}

.login-status {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 4px;
}

.sync-icon {
  font-size: 12px;
}

.sync-text {
  font-size: 12px;
  color: #52c41a;
}

.edit-btn, .login-btn {
  background: #D9A13B;
  color: white;
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 12px;
  flex-shrink: 0;
}

/* 登录提示卡片 */
.login-tip-card {
  display: flex;
  align-items: center;
  gap: 12px;
  background: linear-gradient(135deg, #FEF3E4 0%, #FFF0E0 100%);
  padding: 16px;
  border-radius: 20px;
  margin-bottom: 16px;
  border: 1px solid #FCE5D2;
}

.tip-icon {
  font-size: 32px;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 14px;
  font-weight: 600;
  color: #3E2C1F;
  margin-bottom: 4px;
}

.tip-desc {
  font-size: 12px;
  color: #B3A28E;
}

.tip-btn {
  background: #D9A13B;
  color: white;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
}

/* 同步卡片 */
.sync-card {
  background: white;
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 16px;
  border: 1px solid #F2E8DF;
}

.sync-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.sync-title {
  font-size: 14px;
  font-weight: 600;
  color: #3E2C1F;
}

.sync-time {
  font-size: 12px;
  color: #B3A28E;
}

.sync-actions {
  display: flex;
  gap: 12px;
}

.sync-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  background: #FEF3E4;
  border-radius: 16px;
}

.sync-btn-icon {
  font-size: 20px;
  margin-bottom: 4px;
}

.sync-btn-text {
  font-size: 12px;
  color: #B45F2B;
}

/* 设置项 */
.settings-item {
  background: white;
  border-radius: 20px;
  padding: 14px 16px;
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid #F2E8DF;
}

.settings-value {
  color: #B3A28E;
}

/* 退出登录按钮 */
.logout-btn {
  margin-top: 24px;
  text-align: center;
  padding: 14px;
  color: #B3A28E;
  font-size: 14px;
}

/* ========== 登录弹窗 ========== */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal-content {
  width: 300px;
  background: white;
  border-radius: 24px;
  padding: 32px 24px;
  box-sizing: border-box;
  position: relative;
}

.login-logo {
  font-size: 48px;
  text-align: center;
  margin-bottom: 16px;
}

.login-title {
  font-size: 20px;
  font-weight: 600;
  color: #3E2C1F;
  text-align: center;
  margin-bottom: 8px;
}

.login-desc {
  font-size: 13px;
  color: #B3A28E;
  text-align: center;
  margin-bottom: 24px;
}

.login-wechat-btn, .login-phone-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  height: 48px;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 500;
  box-sizing: border-box;
}

.login-wechat-btn {
  background: #07C160;
  color: white;
  border: none;
}

.login-phone-btn {
  background: #D9A13B;
  color: white;
  margin-top: 12px;
}

.login-btn-icon {
  font-size: 18px;
}

.login-divider {
  display: flex;
  align-items: center;
  margin: 20px 0;
}

.divider-line {
  flex: 1;
  height: 1px;
  background: #F2E8DF;
}

.divider-text {
  padding: 0 16px;
  font-size: 12px;
  color: #B3A28E;
}

.login-agreement {
  margin-top: 20px;
  text-align: center;
  font-size: 11px;
  color: #B3A28E;
}

.agreement-link {
  color: #D9A13B;
}

.login-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #B3A28E;
}

/* ========== 头像选择弹窗 ========== */
.avatar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.avatar-modal-content {
  width: 320px;
  max-height: 80vh;
  overflow-y: auto;
  background: white;
  border-radius: 24px;
  padding: 20px;
  box-sizing: border-box;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #3E2C1F;
  text-align: center;
  margin-bottom: 20px;
}

.wechat-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 16px;
}

.wechat-avatar-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  border-radius: 16px;
  border: 2px solid transparent;
}

.wechat-avatar-option.selected {
  border-color: #D9A13B;
  background: #FFF0E0;
}

.wechat-avatar-preview {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  margin-bottom: 8px;
}

.wechat-avatar-label {
  font-size: 12px;
  color: #3E2C1F;
}

.avatar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
  margin-bottom: 20px;
}

.avatar-option {
  width: 48px;
  height: 48px;
  background: #F7E5D3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  border: 2px solid transparent;
  box-sizing: border-box;
}

.avatar-option.selected {
  border-color: #D9A13B;
  background: #FFF0E0;
}

.upload-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20px;
}

.upload-btn {
  background: #FEF3E4;
  color: #B45F2B;
  border-radius: 40px;
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 500;
  border: 1px solid #F2E8DF;
}

.preview-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-top: 12px;
}

.modal-buttons {
  display: flex;
  gap: 12px;
}

.modal-btn {
  flex: 1;
  padding: 12px;
  border-radius: 40px;
  text-align: center;
  font-weight: 600;
  font-size: 14px;
}

.modal-btn.cancel {
  background: #F7F3EE;
  color: #B3A28E;
}

.modal-btn.confirm {
  background: #D9A13B;
  color: white;
}

/* ========== 昵称编辑弹窗 ========== */
.nickname-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.nickname-modal-content {
  width: 300px;
  background: white;
  border-radius: 24px;
  padding: 20px;
  box-sizing: border-box;
}

.nickname-input {
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border-radius: 24px;
  border: 1px solid #E8DDD2;
  background: white;
  font-size: 14px;
  color: #3E2C1F;
  box-sizing: border-box;
  text-align: center;
}

.nickname-tip {
  font-size: 12px;
  color: #B3A28E;
  text-align: center;
  margin-top: 8px;
  margin-bottom: 12px;
}

.sync-wechat-btn {
  text-align: center;
  padding: 10px;
  background: #FEF3E4;
  border-radius: 20px;
  font-size: 13px;
  color: #B45F2B;
  margin-bottom: 16px;
}