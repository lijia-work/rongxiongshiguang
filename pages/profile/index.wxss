/* pages/profile/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  gap: 16px;
  background: #FEF8F0;
  padding: 16px;
  border-radius: 28px;
  margin-bottom: 24px;
  margin-top: 16px;
}

.user-avatar {
  width: 56px;
  height: 56px;
  background: #E3D5C5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.user-info-text {
  flex: 1;
}

.user-name {
  font-weight: 600;
  font-size: 18px;
  color: #3E2C1F;
}

.edit-btn {
  background: #D9A13B;
  color: white;
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 12px;
}

/* 设置项 */
.settings-item {
  background: white;
  border-radius: 20px;
  padding: 14px 16px;
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid #F2E8DF;
}

.settings-value {
  color: #B3A28E;
}