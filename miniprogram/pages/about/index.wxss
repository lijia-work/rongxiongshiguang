/* pages/about/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30px 0;
}

.logo {
  width: 80px;
  height: 80px;
  background: #F7E5D3;
  border-radius: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  margin-bottom: 16px;
}

.app-name {
  font-size: 24px;
  font-weight: 600;
  color: #3E2C1F;
  margin-bottom: 8px;
}

.slogan {
  font-size: 14px;
  color: #B3A28E;
}

.info-card {
  background: white;
  border-radius: 24px;
  padding: 4px 16px;
  margin-bottom: 20px;
  border: 1px solid #F2E8DF;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid #F2E8DF;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #B3A28E;
}

.info-value {
  color: #3E2C1F;
  font-weight: 500;
}

.section-title {
  font-size: 14px;
  color: #B3A28E;
  margin-bottom: 8px;
  padding-left: 4px;
}

.update-card {
  background: white;
  border-radius: 24px;
  padding: 16px;
  border: 1px solid #F2E8DF;
}

.update-item {
  padding-bottom: 12px;
}

.update-version {
  font-weight: 600;
  color: #D9A13B;
  margin-bottom: 4px;
}

.update-date {
  font-size: 12px;
  color: #B3A28E;
  margin-bottom: 8px;
}

.update-content {
  font-size: 13px;
  color: #3E2C1F;
  line-height: 1.6;
}

.copyright {
  text-align: center;
  margin-top: 40px;
  color: #B3A28E;
  font-size: 12px;
  line-height: 1.8;
}