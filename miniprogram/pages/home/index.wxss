/* pages/home/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 120px;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16px;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #FEF3E4;
  border-radius: 30px;
  padding: 8px 16px;
}

.search-icon {
  font-size: 16px;
  margin-right: 8px;
}

.search-input {
  flex: 1;
  font-size: 14px;
  background: transparent;
}

.clear-btn {
  font-size: 14px;
  color: #B3A28E;
  padding: 4px;
}

/* 提醒栏 */
.reminder-bar {
  background: #FEF3E4;
  border-radius: 24px;
  padding: 12px 16px;
  margin-bottom: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid #FCE5D2;
}

.reminder-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.reminder-bell {
  font-size: 22px;
}

.reminder-text {
  font-size: 14px;
  font-weight: 500;
  color: #B45F2B;
}

.reminder-badge {
  background: #D9A13B;
  color: white;
  border-radius: 30px;
  padding: 4px 12px;
  font-size: 12px;
}

/* 区块标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #3E2C1F;
}

.add-btn {
  font-size: 14px;
  color: #D9A13B;
}

/* 宠物卡片 */
.pet-card {
  background: white;
  border-radius: 24px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
  border: 1px solid #F2E8DF;
  display: flex;
  align-items: center;
  gap: 14px;
}

.pet-avatar {
  width: 56px;
  height: 56px;
  background: #F7E5D3;
  border-radius: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-weight: 700;
  font-size: 16px;
  color: #3E2C1F;
}

.pet-days {
  font-size: 12px;
  color: #B3A28E;
  margin-top: 4px;
}

.arrow {
  color: #D9A13B;
  font-size: 18px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40px 0;
  color: #B3A28E;
  font-size: 14px;
}

/* 悬浮按钮 */
.float-add-btn {
  position: fixed;
  right: 20px;
  bottom: 120px;
  width: 50px;
  height: 50px;
  background: #D9A13B;
  border-radius: 25px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28px;
  font-weight: bold;
  box-shadow: 0 4px 12px rgba(217, 161, 59, 0.3);
}

/* 操作菜单 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.action-menu {
  background: white;
  width: 260px;
  border-radius: 32px;
  padding: 16px 0;
  box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.2);
}

.menu-item {
  padding: 14px 24px;
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 16px;
  font-weight: 500;
  border-bottom: 0.5px solid #F0E5DC;
  color: #3E2C1F;
}

.menu-item:last-of-type {
  border-bottom: none;
}

.menu-item:active {
  background: #F7F3EE;
}

.menu-icon {
  font-size: 22px;
  width: 32px;
}

.menu-close {
  text-align: center;
  font-size: 12px;
  color: #aaa;
  margin-top: 12px;
}