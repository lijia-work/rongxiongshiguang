/* pages/petDetail/index.wxss */

.container {
  padding: 16px;
  padding-bottom: 100px;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin: 20px 0;
}

.avatar-large {
  width: 100px;
  height: 100px;
  background: #F7E5D3;
  border-radius: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid #F2E8DF;
}

.info-label {
  color: #B3A28E;
  font-weight: 500;
}

.info-value {
  font-weight: 500;
  color: #3E2C1F;
}

.module-entry {
  background: #FEFAF5;
  border-radius: 20px;
  padding: 12px 16px;
  margin: 12px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid #F2E8DF;
}

.arrow {
  color: #D9A13B;
}

.action-buttons {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn-secondary {
  flex: 1;
  background: #FEF3E4;
  border-radius: 40px;
  padding: 12px;
  text-align: center;
  font-weight: 600;
  color: #B45F2B;
  border: 1px solid #F2E8DF;
}