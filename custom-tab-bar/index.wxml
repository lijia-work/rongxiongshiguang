<!--custom-tab-bar/index.wxml-->
<view class="tab-bar">
  <!-- 首页 -->
  <view
    class="tab-item {{selected === 0 ? 'active' : ''}}"
    data-path="/pages/home/index"
    data-index="0"
    bindtap="switchTab"
  >
    <text class="tab-icon">🏠</text>
    <text class="tab-text">首页</text>
  </view>

  <!-- 中间加号按钮 -->
  <view class="tab-center-btn" bindtap="onAddTap">
    <view class="center-btn-inner">
      <text class="center-btn-icon">+</text>
    </view>
  </view>

  <!-- 我的 -->
  <view
    class="tab-item {{selected === 1 ? 'active' : ''}}"
    data-path="/pages/profile/index"
    data-index="1"
    bindtap="switchTab"
  >
    <text class="tab-icon">👤</text>
    <text class="tab-text">我的</text>
  </view>
</view>
